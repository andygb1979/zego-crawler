{
  "name": "zego-crawler",
  "version": "1.0.0",
  "description": "Concurrent same-domain web crawler",
  "main": "./src/crawler.js",
  "bin": {
    "crawl": "./src/index.js"
  },
  "scripts": {
    "start": "NODE_CONFIG_DIR=./src/config node src/index.js",
    "test:unit": "NODE_CONFIG_DIR=./src/config mocha 'test/**/*.test.js'",
    "test": "npm run test:unit && npm run check",
    "coverage": "NODE_CONFIG_DIR=./src/config c8 --reporter=text --reporter=text-summary --reporter=html mocha 'test/**/*.test.js'",
    "check": "NODE_CONFIG_DIR=./src/config c8 --check-coverage --lines 75 --functions 75 --branches 75 --statements 75 --reporter=text --reporter=text-summary mocha 'test/**/*.test.js'"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^15.0.0",
    "config": "^4.4.1",
    "got": "^15.0.5"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "chai": "^4.5.0",
    "mocha": "^11.7.6",
    "sinon": "^22.0.0"
  },
  "c8": {
    "all": true,
    "include": [
      "src/**/*.js"
    ],
    "exclude": [
      "test/**"
    ],
    "check-coverage": false,
    "lines": 75,
    "functions": 75,
    "branches": 75,
    "statements": 75,
    "reporter": [
      "text",
      "html"
    ]
  }
}
